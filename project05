def find_gcd(a, b):
    while b != 0:
        a, b = b, a % b
    return a

def find_lcm(a, b):
    return (a * b) // find_gcd(a, b)

ans = 1

for i in range(1, 21):
    ans = find_lcm(ans, i)

print("The smallest positive number evenly divisible by 1 to 20 is:", ans)

#gcd - Greatest Common Divisor
